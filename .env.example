# Copy this file to .env for local development.
# .env is intentionally ignored by git. Never commit real API keys.

# Required for Torn API calls. Prefer a Torn key with the minimum access level
# needed for the endpoint you are testing.
TORN_API_KEY=your_torn_api_key_here

# Required for FFScouter API calls.
FFSCOUTER_API_KEY=your_ffscouter_api_key_here

# Defaults; override only for tests, mocks, or documented API changes.
TORN_BASE_URL=https://api.torn.com/v2
FFSCOUTER_BASE_URL=https://ffscouter.com/api/v1

# Optional local paths. Leave empty to use platform defaults.
TORN_API_INDEX_PATH=
TORN_CACHE_DIR=
TORN_CONFIG_DIR=
