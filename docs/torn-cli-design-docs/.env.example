# Example local environment for torn-cli.
# Copy to .env for local testing; never commit real keys.

TORN_API_KEY=your_torn_api_key_here
FFSCOUTER_API_KEY=your_ffscouter_api_key_here

TORN_BASE_URL=https://api.torn.com/v2
FFSCOUTER_BASE_URL=https://ffscouter.com/api/v1

# Optional local overrides. Leave empty to use platform defaults.
TORN_API_INDEX_PATH=
TORN_CACHE_DIR=
TORN_CONFIG_DIR=
